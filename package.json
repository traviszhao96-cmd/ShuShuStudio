{
  "name": "ssmaster",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:cases": "node scripts/migrate-cases-db.mjs && node scripts/import-mingli-bench-sample.mjs && node scripts/export-cases-from-sqlite.mjs",
    "reverse:ziwei-chart": "node scripts/reverse-ziwei-chart.mjs",
    "reverse:ziwei-session": "node scripts/reverse-ziwei-session.mjs",
    "reverse:ziwei-time": "node scripts/reverse-ziwei-time.mjs",
    "predev": "npm run sync:cases",
    "prebuild": "npm run sync:cases",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "android:add": "cap add android",
    "android:sync": "npm run build:web && cap sync android",
    "android:build:debug": "npm run android:sync && cd android && JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home ./gradlew assembleDebug",
    "android:install:debug": "cd android && JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home ./gradlew installDebug",
    "android:open": "cap open android",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-community/http": "^1.4.1",
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "html2canvas": "^1.4.1",
    "iztro": "2.5.3",
    "iztro-hook": "^1.3.3",
    "lucide-react": "^1.17.0",
    "lunar-typescript": "^1.8.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-iztro": "^1.4.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
